MANIFEST
*.pyd

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ============================================================
# DFIR / Forensics artifacts (never commit real evidence)
# ============================================================

# Evidence stores - contain real case data
evidence_store/*/
!evidence_store/.gitkeep

# Generated reports with case data
reports/IR-*/
reports/*.html
reports/*.pdf
reports/*.txt

# Memory dumps and disk images (too large, potentially sensitive)
*.dmp
*.vmem
*.raw
*.dd
*.e01
*.ex01
*.aff
*.aff4

# PCAP files (may contain sensitive data)
*.pcap
*.pcapng
*.cap

# Case output directories
cases/IR-*/
hunt_results/TH-*/
triage_output/

# ============================================================
# Configuration files with secrets
# ============================================================

# API keys and credentials
.env
*.env
config.local.yaml
config.local.json
secrets.yaml
secrets.json
credentials.json
*.key
*.pem
*.p12

# Local overrides
configs/local/
settings.local.*

# ============================================================
# IDE & Editor
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Jupyter / Notebooks
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# Testing
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ============================================================
# Logs
# ============================================================
*.log
logs/
*.log.*

# ============================================================
# OS
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# Large binary test samples (commit hashes only, not binaries)
# ============================================================
tests/samples/*.exe
tests/samples/*.dll
tests/samples/*.bin
tests/samples/*.doc
tests/samples/*.docx
tests/samples/*.xls
